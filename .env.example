# ─────────────────────────────────────────────────────
# ISKCON Book Store - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key

# Database
# Local SQLite (default, no change needed):
# DATABASE_URL=sqlite:///iskcon_books.db
# PostgreSQL (cloud):
DATABASE_URL=postgresql://user:password@host:5432/iskcon_books

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Hare@Krishna108

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp number for order notifications (with country code)
WHATSAPP_NUMBER=+919999999999

# Store settings
SHIPPING_CHARGE=50
FREE_SHIPPING_ABOVE=500

# Server
HOST=0.0.0.0
PORT=5000
FLASK_ENV=production
